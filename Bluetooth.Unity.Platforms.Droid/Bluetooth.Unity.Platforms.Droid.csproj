<Project Sdk="Microsoft.NET.Sdk">

    <!-- ==================== CORE VARIABLES ==================== -->
    <PropertyGroup>
        <Project_Name>Bluetooth.Unity.Platforms.Droid</Project_Name>
        <Project_Tags>Bluetooth;Unity;Android;Tools;Toolkit</Project_Tags>
        <Project_Copyright>Francois Raminosona</Project_Copyright>
        <Project_Description>Android platform implementation for Bluetooth.Unity</Project_Description>
        <AssemblyName>Bluetooth.Unity.Platforms.Droid</AssemblyName>
        <PackageId>Bluetooth.Unity.Platforms.Droid</PackageId>
    </PropertyGroup>

    <!-- ==================== NOWARNINGS ==================== -->
    <PropertyGroup>
        <NoWarn>$(NoWarn);CA1034</NoWarn>
        <NoWarn>$(NoWarn);CA1032</NoWarn>
        <NoWarn>$(NoWarn);CA1816</NoWarn>
    </PropertyGroup>

    <!-- ==================== TARGET FRAMEWORKS ==================== -->
    <PropertyGroup>
        <TargetFramework>net10.0-android</TargetFramework>
    </PropertyGroup>

    <!-- ==================== PACKAGING ==================== -->
    <PropertyGroup>
        <IsPackable Condition="'$(Configuration)' == 'Release'">false</IsPackable>
    </PropertyGroup>

    <!-- ==================== SOURCE : link MAUI Droid platform code ==================== -->
    <!-- Excludes GlobalUsings, root ServiceCollectionExtensions, Permissions (replaced by Unity compat shims),
         and generated files in obj/ to avoid duplicate assembly attributes. -->
    <ItemGroup>
        <Compile Include="../Bluetooth.Maui.Platforms.Droid/**/*.cs"
                 Exclude="../Bluetooth.Maui.Platforms.Droid/GlobalUsings.cs;
                          ../Bluetooth.Maui.Platforms.Droid/ServiceCollectionExtensions.cs;
                          ../Bluetooth.Maui.Platforms.Droid/Permissions/*.cs;
                          ../Bluetooth.Maui.Platforms.Droid/obj/**/*.cs" />
    </ItemGroup>

    <!-- ==================== PACKAGE REFERENCES / DEPENDENCIES ==================== -->
    <ItemGroup>
        <ProjectReference Include="../Bluetooth.Abstractions/Bluetooth.Abstractions.csproj" PrivateAssets="all" />
        <ProjectReference Include="../Bluetooth.Abstractions.Scanning/Bluetooth.Abstractions.Scanning.csproj" PrivateAssets="all" />
        <ProjectReference Include="../Bluetooth.Abstractions.Broadcasting/Bluetooth.Abstractions.Broadcasting.csproj" PrivateAssets="all" />

        <ProjectReference Include="../Bluetooth.Core/Bluetooth.Core.csproj" PrivateAssets="all" />
        <ProjectReference Include="../Bluetooth.Core.Broadcasting/Bluetooth.Core.Broadcasting.csproj" PrivateAssets="all" />
        <ProjectReference Include="../Bluetooth.Core.Scanning/Bluetooth.Core.Scanning.csproj" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Plugin.ByteArrays" />
        <PackageReference Include="Plugin.BaseTypeExtensions" />
        <PackageReference Include="Plugin.ExceptionListeners" />
    </ItemGroup>

</Project>
